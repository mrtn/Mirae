<?xml version="1.0"?>
<ruleset name="Mirae">
	<description>PHPCS configuration for the Mirae plugin.</description>

	<!-- What to scan. -->
	<file>.</file>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/admin/js/jquery.tablednd*</exclude-pattern>

	<!-- Output options. -->
	<arg value="ps"/>
	<arg name="extensions" value="php"/>
	<arg name="colors"/>

	<!-- WordPress-Core + WordPress-Extra: the rules wordpress.org reviewers run.
	     We deliberately skip WordPress-Docs (docblock formatting), which is the
	     pedantic set without security/correctness value. -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Extra">
		<!-- Yoda conditions are a style preference, not a safety net. -->
		<exclude name="WordPress.PHP.YodaConditions"/>
		<!-- We use a custom pattern for class names to match the WPPB layout. -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<!-- PHP version compatibility check. -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- Project text-domain for i18n sniffs. -->
	<config name="text_domain" value="mirae"/>
</ruleset>
